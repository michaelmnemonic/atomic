{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "mkosi: build",
            "detail": "Builds an image locally",
            "type": "shell",
            "command": "../mkosi/bin/mkosi --force",
            "group": "build",
        },
        {
            "label": "atomic: bump",
            "detail": "Determines if a more recent archive snapshots exists",
            "type": "shell",
            "command": "${workspaceFolder}/.scripts/bump_snapshot.py",
            "problemMatcher": []
        },
        {
            "label": "mkosi: deploy",
            "detail": "Deploys the most recent locally build image to the device",
            "type": "shell",
            "command": "run0 /usr/lib/systemd/systemd-sysupdate --definitions mkosi.sysupdate/ --transfer-source mkosi.output/ update",
            "problemMatcher": []
        },
        {
            "label": "mkosi: build --> deploy",
            "detail": "Builds and then deploys the image",
            "dependsOrder": "sequence",
            "dependsOn": [
                "mkosi: build",
                "mkosi: deploy"
            ],
            "problemMatcher": []
        }
    ]
}
