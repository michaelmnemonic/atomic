#!/bin/bash
# SPDX-License-Identifier: LGPL-2.1-or-later
# atomic-veritysetup-helper — Extract root hash and open dm-verity device
#
# Called by atomic-veritysetup-usr.service (generated by atomic-usr-dissect generator).
#
# Arguments:
#   $1 — path to the /usr data partition device (e.g., /dev/disk/by-label/juno_0.0.2)
#   $2 — path to the verity hash partition device (e.g., /dev/disk/by-label/juno_0.0.2_verity)
#
# Steps:
#   1. Wait for both devices to appear (udev creates by-label symlinks)
#   2. Extract root hash from the verity superblock via veritysetup dump
#   3. Open the dm-verity device as /dev/mapper/usr

set -euo pipefail

USR_DEV="${1:?Usage: atomic-veritysetup-helper <usr-dev> <verity-dev>}"
VERITY_DEV="${2:?Missing verity device path}"

MAX_WAIT_SEC=30

echo "atomic-veritysetup-helper: Waiting for devices..." >&2
echo "  usr:     $USR_DEV" >&2
echo "  verity:  $VERITY_DEV" >&2

# --- Wait for devices to appear ---
# udev creates /dev/disk/by-label/ symlinks asynchronously.
# In the initrd, systemd-udevd is typically running but may not have
# processed all partitions yet when this service starts.
# Uses integer seconds with bash arithmetic (no external deps like bc).
elapsed=0
while [[ ! -e "$USR_DEV" ]] || [[ ! -e "$VERITY_DEV" ]]; do
    if (( elapsed >= MAX_WAIT_SEC )); then
        echo "atomic-veritysetup-helper: TIMEOUT waiting for devices after ${MAX_WAIT_SEC}s" >&2
        echo "  usr present: $([[ -e "$USR_DEV" ]] && echo yes || echo no)" >&2
        echo "  verity present: $([[ -e "$VERITY_DEV" ]] && echo yes || echo no)" >&2
        exit 1
    fi
    sleep 1
    ((elapsed++))
done

echo "atomic-veritysetup-helper: Devices found (waited ${elapsed}s)" >&2

# --- Resolve to real device paths ---
# /dev/disk/by-label/... may be a symlink — resolve it for veritysetup
USR_REAL="$(readlink -f "$USR_DEV")"
VERITY_REAL="$(readlink -f "$VERITY_DEV")"

echo "atomic-veritysetup-helper: Resolved devices:" >&2
echo "  usr:     $USR_REAL" >&2
echo "  verity:  $VERITY_REAL" >&2

# --- Extract root hash from verity superblock ---
# veritysetup dump reads the dm-verity superblock from the hash device.
# The root hash is the cryptographic commitment to the entire /usr tree.
ROOT_HASH="$(/sbin/veritysetup dump "$VERITY_REAL" 2>/dev/null | awk '/Root hash:/ {print $3}')"

if [[ -z "$ROOT_HASH" ]]; then
    echo "atomic-veritysetup-helper: Failed to extract root hash from $VERITY_REAL" >&2
    echo "  Is this a valid dm-verity hash partition?" >&2
    exit 1
fi

echo "atomic-veritysetup-helper: Root hash: $ROOT_HASH" >&2

# --- Open the dm-verity device ---
# This creates /dev/mapper/usr which the mount unit will use.
# The mapped device provides integrity verification: any tampering with
# the /usr data partition will cause reads to fail with EIO.
/sbin/veritysetup open \
    --no-writes \
    "$USR_REAL" \
    "$VERITY_REAL" \
    usr \
    "$ROOT_HASH"

echo "atomic-veritysetup-helper: dm-verity device /dev/mapper/usr is ready" >&2