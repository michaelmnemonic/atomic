# SPDX-License-Identifier: LGPL-2.1-or-later

[Transfer]
ProtectVersion=%A

[Source]
Type=regular-file
Path=/
PathRelativeTo=explicit
MatchPattern=%H_@v_%a.efi

[Target]
Type=regular-file
Path=/EFI/Linux
PathRelativeTo=boot
MatchPattern=%H_@v_%a+@l-@d.efi \
             %H_@v_%a+@l.efi \
             %H_@v_%a.efi \
             %H_@v+@l-@d.efi \
             %H_@v+@l.efi \
             %H_@v.efi
Mode=0600
TriesLeft=3
TriesDone=0
InstancesMax=3
